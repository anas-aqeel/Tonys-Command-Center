SHARED_DATABASE_URL=postgresql://postgres.TONYS_PROJECT:PASSWORD@aws-X-us-west-1.pooler.supabase.com:6543/postgres

# PERSONAL: Your own Supabase — personal data, agent training, chat
PERSONAL_DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-X-us-west-1.pooler.supabase.com:6543/postgres

# Legacy fallbacks (used if SHARED/PERSONAL not set):
