VITE_USER_NAME=Ethan Jolly
VITE_USER_EMAIL=ethan@flipiq.com
VITE_ACCOUNTABILITY_EMAIL=tony@flipiq.com
VITE_EMAIL_DOMAIN=flipiq.com

# ── Agent Runtime Flags ───────────────────────────────────
FEEDBACK_PIPELINE_ENABLED=true
AGENT_RUNTIME_ORCHESTRATOR=true
AGENT_RUNTIME_EMAIL=true
AGENT_RUNTIME_TASKS=true
AGENT_RUNTIME_IDEAS=true
AGENT_RUNTIME_BRIEF=true
AGENT_RUNTIME_CONTACTS=true
AGENT_RUNTIME_CALLS=true
