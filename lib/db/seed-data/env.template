# ── User Identity ─────────────────────────────────────────
TCC_USER_NAME=Ethan Jolly
TCC_USER_EMAIL=ethan@flipiq.com
TCC_USER_SLACK_ID=U0991BD321Y
TCC_USER_ROLE=COO
TCC_ACCOUNTABILITY_EMAIL=tony@flipiq.com
TCC_ACCOUNTABILITY_SLACK_ID=U0991BAS0TC
