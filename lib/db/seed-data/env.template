# ── Authentication ─────────────────────────────────────────
TCC_AUTH_TOKEN=<unique-pin-for-this-user>
SESSION_SECRET=<random-string>

# ── AI / LLM ──────────────────────────────────────────────
AI_INTEGRATIONS_ANTHROPIC_API_KEY=<anthropic-api-key>
ANTHROPIC_API_KEY=<same-key-as-above>
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
SETTINGS_ENCRYPTION_KEY=<unique-64-hex-chars-per-instance>

# ── Google OAuth (per-user Google account) ─────────────────
GOOGLE_CLIENT_ID=<gcp-oauth-client-id>
GOOGLE_CLIENT_SECRET=<gcp-oauth-client-secret>
GOOGLE_REFRESH_TOKEN=<per-user-refresh-token>

# ── Integrations ──────────────────────────────────────────
SLACK_TOKEN=<slack-bot-token>
LINEAR_API_KEY=<linear-api-key>
RESEND_API_KEY=<resend-api-key>
BUSINESS_MASTER_SHEET_ID=<shared-google-sheet-id>

# ── Per-User Google Sheets/Docs (optional — leave blank to disable) ──
CHECKIN_SHEET_ID=                     # Google Sheet with "Daily Check-in" tab
JOURNAL_DOC_ID=                       # Google Doc for journal entries

MACRODROID_SECRET=<per-user-macrodroid-secret>
MACRODROID_WEBHOOK_URL=<per-user-macrodroid-webhook>

# ── Cron Control ──────────────────────────────────────────
CRON_PLAN_INGEST_ENABLED=false   # Only Tony's instance should run plan-ingest
CRON_EOD_ENABLED=true            # Each user runs their own EOD

# ── Server ────────────────────────────────────────────────
